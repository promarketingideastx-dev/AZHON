generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis]
}

// ==========================================
// IAM & TENANT
// ==========================================
model Tenant {
  id              String   @id @default(uuid())
  countryCode     String   @unique // 'HN', 'MX'
  currencyCode    String   // 'HNL', 'MXN'
  taxRate         Decimal  @db.Decimal(5,2)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())

  Users           User[]
  Stores          Store[]
  Products        Product[]
  Orders          Order[]
  RiskZones       RiskZone[]
}

model User {
  id        String   @id // UUID de Supabase Auth
  tenantId  String
  email     String
  role      String   @default("BUYER") // BUYER, SELLER, SUPER_ADMIN
  createdAt DateTime @default(now())
  deletedAt DateTime? 

  Tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  Stores    Store[]  @relation("StoreOwner")
  Orders    Order[]

  @@unique([tenantId, email])
}

// ==========================================
// B2B & CATALOG
// ==========================================
model Store {
  id              String   @id @default(uuid())
  tenantId        String
  ownerId         String
  name            String
  planType        String   @default("STANDARD") // STANDARD, PREMIUM_FBA
  kycStatus       String   @default("PENDING")
  createdAt       DateTime @default(now())
  deletedAt       DateTime?

  Tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  Owner           User     @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  Products        Product[]
  OrderLines      OrderLine[]
  Shipments       Shipment[]
  EscrowLedgers   EscrowLedger[]
}

model Product {
  id              String   @id @default(uuid())
  tenantId        String
  storeId         String
  title           String
  description     String   @db.Text
  basePrice       Int
  imageUrl        String?
  fulfillmentType String   @default("SELLER_MANAGED") 
  
  // Postgres Full-Text Search
  searchVector    Unsupported("tsvector")? 
  
  createdAt       DateTime @default(now())
  deletedAt       DateTime?

  Tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  Store           Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  Variants        ProductVariant[]
  
  @@index([searchVector]) 
}

model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  sku         String
  attributes  Json     
  stockQty    Int      @default(0) 
  deletedAt   DateTime?

  Product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  OrderLines  OrderLine[]

  @@unique([productId, sku])
}

// ==========================================
// TRANSACTIONAL & LOGISTICS
// ==========================================
model Order {
  id             String   @id @default(uuid())
  tenantId       String
  buyerId        String
  baseTotal      Int
  taxTotal       Int
  shippingTotal  Int
  grandTotal     Int
  status         String   @default("AWAITING_PAYMENT") 
  deliveryAddress Json    
  createdAt      DateTime @default(now())

  Tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  Buyer          User     @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  OrderLines     OrderLine[]
  Shipments      Shipment[]
  Transactions   Transaction[]
}

model OrderLine {
  id            String   @id @default(uuid())
  orderId       String
  storeId       String
  variantId     String
  qty           Int
  unitPriceSnap Int

  Order         Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  Store         Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  Variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  ShipmentItem  ShipmentItem?
}

model RiskZone {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  riskLevel   String   // HIGH, BLACKLISTED
  polygonGeom Unsupported("geometry(Polygon, 4326)")? 

  Tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
}

model Shipment {
  id              String   @id @default(uuid())
  orderId         String
  storeId         String
  trackingNumber  String?  @unique
  status          String   @default("PREPARING") 
  destinationType String   @default("HOME") // HOME, LOCKER
  createdAt       DateTime @default(now())

  Order           Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  Store           Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  ShipmentItems   ShipmentItem[]
  DeliveryEvents  DeliveryEvent[]
}

model ShipmentItem {
  id          String   @id @default(uuid())
  shipmentId  String
  orderLineId String   @unique
  qty         Int

  Shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Restrict)
  OrderLine   OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Restrict)
}

model DeliveryEvent {
  id          String   @id @default(uuid())
  shipmentId  String
  status      String   
  location    String?
  timestamp   DateTime @default(now())

  Shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Restrict)
}

// ==========================================
// FINANCE (Append-Only)
// ==========================================
model Transaction {
  id              String   @id @default(uuid())
  orderId         String
  providerId      String   
  amount          Int
  status          String   
  payload         Json?
  createdAt       DateTime @default(now())

  Order           Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
}

model EscrowLedger {
  id          String   @id @default(uuid())
  storeId     String
  orderId     String   
  amount      Int
  entryType   String   // CREDIT, DEBIT
  reason      String   // HOLD, RELEASE, REFUND
  createdAt   DateTime @default(now())

  Store       Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  
  @@index([storeId, createdAt])
}
