generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis]
}

// ==========================================
// IAM & TENANT
// ==========================================
model Tenant {
  id           String   @id @default(uuid())
  countryCode  String   @unique // 'HN', 'MX'
  currencyCode String // 'HNL', 'MXN'
  taxRate      Decimal  @db.Decimal(5, 2)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())

  Users            User[]
  Stores           Store[]
  Products         Product[]
  Orders           Order[]
  RiskZones        RiskZone[]
  Categories       Category[]
  Warehouses       Warehouse[]
  InboundRequests  InboundRequest[]
  InventoryLedgers InventoryLedger[]
  StockMovements   StockMovement[]
}

model User {
  id        String    @id // UUID de Supabase Auth
  tenantId  String
  email     String
  phone     String?
  role      String    @default("BUYER") // BUYER, SELLER, SUPER_ADMIN
  status    String    @default("PENDING_VERIFICATION") // PENDING_VERIFICATION, ACTIVE, RESTRICTED, SUSPENDED
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  Tenant                 Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  Stores                 Store[]                @relation("StoreOwner")
  Orders                 Order[]
  ReceiptsReceived       WarehouseReceipt[]     @relation("ReceiptReceiver")
  DiscrepanciesValidated WarehouseDiscrepancy[] @relation("DiscrepancyValidator")

  BuyerProfile  BuyerProfile?
  SellerProfile SellerProfile?
  Verifications AccountVerification[]
  Addresses     UserAddress[]
  Preferences   UserPreference?
  Events        AccountEvent[]

  @@unique([tenantId, email])
}

// ==========================================
// B2B & CATALOG
// ==========================================
model Category {
  id        String   @id @default(uuid())
  tenantId  String
  slug      String
  name      String
  parentId  String?
  createdAt DateTime @default(now())

  Tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  Parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  Children Category[] @relation("CategoryHierarchy")
  Products Product[]

  @@unique([tenantId, slug])
}

model Store {
  id        String    @id @default(uuid())
  tenantId  String
  ownerId   String
  name      String
  planType  String    @default("STANDARD") // STANDARD, PREMIUM_FBA
  kycStatus String    @default("PENDING")
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  Tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  Owner           User             @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  Products        Product[]
  OrderLines      OrderLine[]
  Shipments       Shipment[]
  EscrowLedgers   EscrowLedger[]
  InboundRequests InboundRequest[]
}

model Product {
  id              String  @id @default(uuid())
  tenantId        String
  storeId         String
  title           String
  description     String  @db.Text
  basePrice       Int
  imageUrl        String?
  fulfillmentType String  @default("SELLER_MANAGED")
  status          String  @default("DRAFT") // DRAFT, IN_REVIEW, APPROVED, REJECTED, ARCHIVED
  rejectionReason String? @db.Text
  categoryId      String?

  // Postgres Full-Text Search
  searchVector Unsupported("tsvector")?

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  Tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  Store       Store               @relation(fields: [storeId], references: [id], onDelete: Restrict)
  Category    Category?           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  Variants    ProductVariant[]
  Media       ProductMedia[]
  Metrics     ProductMetric?
  Publication ProductPublication?

  @@index([searchVector])
}

model ProductVariant {
  id         String    @id @default(uuid())
  productId  String
  sku        String
  attributes Json
  stockQty   Int       @default(0) // @deprecated - F1: Use InventoryLedger as physical source of truth
  deletedAt  DateTime?

  Product           Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  OrderLines        OrderLine[]
  Media             ProductMedia[]
  InboundItems      InboundItem[]
  InventoryLedgers  InventoryLedger[]
  StockMovements    StockMovement[]
  StockReservations StockReservation[]

  @@unique([productId, sku])
}

model ProductMedia {
  id        String   @id @default(uuid())
  productId String
  variantId String?
  url       String
  mediaType String   @default("IMAGE") // IMAGE, VIDEO
  position  Int      @default(0)
  createdAt DateTime @default(now())

  Product Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  Variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)
}

model ProductMetric {
  id         String   @id @default(uuid())
  productId  String   @unique
  views      Int      @default(0)
  clicks     Int      @default(0)
  salesCount Int      @default(0)
  favorites  Int      @default(0)
  updatedAt  DateTime @updatedAt

  Product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model ProductPublication {
  id          String    @id @default(uuid())
  productId   String    @unique
  tenantId    String
  status      String    @default("HIDDEN") // HIDDEN, SCHEDULED, PUBLISHED, PAUSED
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  Product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ==========================================
// TRANSACTIONAL & LOGISTICS
// ==========================================
model Order {
  id              String   @id @default(uuid())
  tenantId        String
  buyerId         String
  baseTotal       Int
  taxTotal        Int
  shippingTotal   Int
  grandTotal      Int
  status          String   @default("AWAITING_PAYMENT")
  deliveryAddress Json
  createdAt       DateTime @default(now())

  Tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  Buyer             User               @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  OrderLines        OrderLine[]
  Shipments         Shipment[]
  Transactions      Transaction[]
  StockReservations StockReservation[]
}

model OrderLine {
  id            String @id @default(uuid())
  orderId       String
  storeId       String
  variantId     String
  qty           Int
  unitPriceSnap Int

  Order        Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  Store        Store          @relation(fields: [storeId], references: [id], onDelete: Restrict)
  Variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  ShipmentItem ShipmentItem?
}

model RiskZone {
  id          String                                  @id @default(uuid())
  tenantId    String
  name        String
  riskLevel   String // HIGH, BLACKLISTED
  polygonGeom Unsupported("geometry(Polygon, 4326)")?

  Tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
}

model Shipment {
  id              String   @id @default(uuid())
  orderId         String
  storeId         String
  trackingNumber  String?  @unique
  status          String   @default("PREPARING")
  destinationType String   @default("HOME") // HOME, LOCKER
  createdAt       DateTime @default(now())

  Order          Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)
  Store          Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  ShipmentItems  ShipmentItem[]
  DeliveryEvents DeliveryEvent[]
}

model ShipmentItem {
  id          String @id @default(uuid())
  shipmentId  String
  orderLineId String @unique
  qty         Int

  Shipment  Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Restrict)
  OrderLine OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Restrict)
}

model DeliveryEvent {
  id         String   @id @default(uuid())
  shipmentId String
  status     String
  location   String?
  timestamp  DateTime @default(now())

  Shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Restrict)
}

// ==========================================
// FINANCE (Append-Only)
// ==========================================
model Transaction {
  id         String   @id @default(uuid())
  orderId    String
  providerId String
  amount     Int
  status     String
  payload    Json?
  createdAt  DateTime @default(now())

  Order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)
}

model EscrowLedger {
  id        String   @id @default(uuid())
  storeId   String
  orderId   String
  amount    Int
  entryType String // CREDIT, DEBIT
  reason    String // HOLD, RELEASE, REFUND
  createdAt DateTime @default(now())

  Store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@index([storeId, createdAt])
}

// ==========================================
// WAREHOUSE & INVENTORY (F1 Foundation)
// ==========================================

model Warehouse {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  location  String?
  type      String   @default("AZHON_CENTRAL") // AZHON_CENTRAL, SELLER_LOCAL, FBA
  createdAt DateTime @default(now())

  Tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  InboundRequests  InboundRequest[]
  InventoryLedgers InventoryLedger[]
  StockMovements   StockMovement[]
}

model InboundRequest {
  id          String    @id @default(uuid())
  tenantId    String
  storeId     String
  warehouseId String
  status      String    @default("DRAFT") // DRAFT, SUBMITTED, IN_TRANSIT, RECEIVING, COMPLETED, CANCELLED
  expectedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  Tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  Store     Store              @relation(fields: [storeId], references: [id], onDelete: Restrict)
  Warehouse Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  Items     InboundItem[]
  Receipts  WarehouseReceipt[]
}

model InboundItem {
  id               String @id @default(uuid())
  inboundRequestId String
  variantId        String
  expectedQty      Int
  status           String @default("PENDING") // PENDING, VERIFIED, DISCREPANCY

  InboundRequest InboundRequest         @relation(fields: [inboundRequestId], references: [id], onDelete: Cascade)
  Variant        ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Restrict)
  Discrepancies  WarehouseDiscrepancy[]
}

model WarehouseReceipt {
  id               String   @id @default(uuid())
  inboundRequestId String
  receiverId       String // User ID (Warehouse Receiver)
  status           String   @default("OPEN") // OPEN, VALIDATING, CLOSED
  receivedAt       DateTime @default(now())

  InboundRequest InboundRequest @relation(fields: [inboundRequestId], references: [id], onDelete: Restrict)
  Receiver       User           @relation("ReceiptReceiver", fields: [receiverId], references: [id], onDelete: Restrict)
}

model WarehouseDiscrepancy {
  id            String    @id @default(uuid())
  inboundItemId String
  validatorId   String // User ID (Warehouse Validator)
  expectedQty   Int
  actualQty     Int
  reason        String?
  status        String    @default("OPEN") // OPEN, RESOLVED, REJECTED
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  InboundItem InboundItem @relation(fields: [inboundItemId], references: [id], onDelete: Restrict)
  Validator   User        @relation("DiscrepancyValidator", fields: [validatorId], references: [id], onDelete: Restrict)
}

model InventoryLedger {
  id           String   @id @default(uuid())
  tenantId     String
  warehouseId  String
  variantId    String
  availableQty Int      @default(0) // Physical - Reserved
  physicalQty  Int      @default(0)
  status       String   @default("AVAILABLE") // AVAILABLE, QUARANTINED, DAMAGED
  updatedAt    DateTime @updatedAt

  Tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  Warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  Variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([warehouseId, variantId])
}

model StockMovement {
  id           String   @id @default(uuid())
  tenantId     String
  warehouseId  String
  variantId    String
  qtyChange    Int // Positive (in) or negative (out)
  movementType String // INBOUND, OUTBOUND, ADJUSTMENT, SALE, RETURN
  referenceId  String? // Ej. orderId, inboundRequestId
  createdAt    DateTime @default(now())

  Tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  Warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  Variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
}

model StockReservation {
  id        String   @id @default(uuid())
  variantId String
  orderId   String? // Nullable until cart turns into confirmed order
  cartId    String? // Temporary session ID
  qty       Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  Variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  Order   Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
}

// ==========================================
// IDENTITY, ACCOUNTS, ONBOARDING & CRM
// ==========================================

model BuyerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  fullName  String?
  status    String   @default("DRAFT") // DRAFT, ACTIVE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SellerProfile {
  id         String @id @default(uuid())
  userId     String @unique
  status     String @default("DRAFT") // DRAFT, IN_PREPARATION, PENDING_DOCUMENTS, UNDER_REVIEW, ACTIVE, RESTRICTED
  sellerType String @default("FORMAL") // FORMAL, REGULARIZATION, INTERNATIONAL_WAITLIST

  commercialName   String?
  businessType     String?
  targetCountries  String[] // Ej. ['HN', 'MX']
  targetCategories String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  OnboardingSessions SellerOnboardingSession[]
  ComplianceRecords  SellerComplianceRecord[]
}

model SellerOnboardingSession {
  id              String    @id @default(uuid())
  sellerProfileId String
  currentStep     String    @default("INTENT") // INTENT, RESIDENCE, TARGET, BUSINESS_TYPE, COMMERCIAL, CATEGORIES, ADDRESS, PAYOUT, DOCUMENTS, SECURITY, COMPLETED
  progressData    Json // Datos en borrador
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  SellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
}

model SellerComplianceRecord {
  id              String    @id @default(uuid())
  sellerProfileId String
  documentType    String // ID, TAX, BANK, INCORPORATION
  documentUrl     String
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewerNotes   String?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())

  SellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
}

model AccountVerification {
  id         String    @id @default(uuid())
  userId     String
  type       String // EMAIL, PHONE, TWO_FACTOR
  status     String    @default("PENDING") // PENDING, VERIFIED, DISABLED
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserAddress {
  id           String  @id @default(uuid())
  userId       String
  countryCode  String
  state        String
  city         String
  zone         String?
  addressLine1 String
  reference    String?
  latitude     Float?
  longitude    Float?
  isPinManual  Boolean @default(false)
  status       String  @default("UNVERIFIED") // UNVERIFIED, VERIFIED, PARTIAL, MANUAL_REVIEW
  isDefault    Boolean @default(false)

  // --- NUCLEO GEO ESTRUCTURADO ---
  cityCode       String?
  departmentCode String?
  citySource     String? @default("catalog") // catalog, manual_request
  cityNameRaw    String? // Nombre real si el usuario usó "No encuentro mi ciudad"

  // --- ESTADOS LOGÍSTICOS (Address Intelligence) ---
  geoStatus           String? @default("pending_review") // pending_geocode, pending_review, geocoded, invalid_location
  coverageStatus      String? @default("pending_review") // pending_review, covered, out_of_bounds, restricted
  deliveryEligibility String? @default("pending_review") // pending_review, door_delivery, pickup_required, locker_required, no_delivery
  addressSource       String? @default("user_selected") // user_selected, manual_request, admin_created, imported
  gpsRequiredLater    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Verifications AddressVerification[]
}

model AddressVerification {
  id          String   @id @default(uuid())
  addressId   String
  status      String // VERIFIED, FAILED, REVIEW_REQUIRED
  provider    String? // Ej. Google Maps, Internal
  rawResponse Json?
  createdAt   DateTime @default(now())

  Address UserAddress @relation(fields: [addressId], references: [id], onDelete: Cascade)
}

model UserPreference {
  id                   String   @id @default(uuid())
  userId               String   @unique
  language             String   @default("es")
  currency             String   @default("HNL")
  marketingOptIn       Boolean  @default(false)
  categoriesOfInterest String[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AccountEvent {
  id        String   @id @default(uuid())
  userId    String
  eventType String // account_created, seller_onboarding_started, etc
  payload   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
